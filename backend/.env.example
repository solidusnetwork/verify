# Database
DATABASE_URL=postgresql://localhost/solidus_verify
SOLIDUS_STUB_DB_URL=postgresql://localhost/solidus_stub

# Queues
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672

# JWT / Identity (run `make bootstrap` to generate these)
SESSION_PRIVATE_KEY=<run make bootstrap to generate>
ISSUER_PRIVATE_KEY=<run make bootstrap to generate>
ISSUER_DID=<run make bootstrap to generate>

# App
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
SOLIDUS_SDK_MODE=stub  # stub | testnet | mainnet — use stub for local dev

# Stripe — get test keys from https://dashboard.stripe.com
# Required even in development (use test keys, not live keys)
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Storage backend — local for dev, s3 for production (R2)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=data/uploads

# Cloudflare R2 (required when STORAGE_BACKEND=s3)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=solidus-verify-documents
