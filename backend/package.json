{
  "name": "@solidus/verify-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "node dist/workers/kyc-worker.js",
    "migrate": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@noble/ed25519": "^2.3.0",
    "@sentry/node": "^10.47.0",
    "@solidus/events": "workspace:*",
    "@solidus/jwt": "workspace:*",
    "@solidus/sdk": "workspace:*",
    "@solidus/types": "workspace:*",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "bullmq": "^5.0.0",
    "canvas": "^3.2.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.4.0",
    "mrz": "^5.0.2",
    "postgres": "^3.4.4",
    "sharp": "^0.34.5",
    "stripe": "^16.0.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@solidus/config": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
